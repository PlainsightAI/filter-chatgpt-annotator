{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:filter-chatgpt-annotator:chattag_output:1.0",
  "title": "ChatTag OpenFilter output",
  "oneOf": [
    { "$ref": "#/$defs/streamPayload" },
    { "$ref": "#/$defs/jsonlLine" }
  ],
  "$defs": {
    "usage": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "total_tokens"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "perLabel": {
      "type": "object",
      "required": ["present", "confidence"],
      "properties": {
        "present": { "type": "boolean" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "annotations": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/perLabel" }
    },
    "streamPayload": {
      "type": "object",
      "required": [
        "schema_version",
        "annotations",
        "usage",
        "processing_time",
        "timestamp",
        "model",
        "frame_id"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "annotations": { "$ref": "#/$defs/annotations" },
        "usage": { "$ref": "#/$defs/usage" },
        "processing_time": { "type": "number", "minimum": 0 },
        "timestamp": { "type": "number" },
        "model": { "type": "string" },
        "frame_id": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "jsonlLine": {
      "type": "object",
      "required": ["schema_version", "image", "labels", "usage", "prompt_used"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "image": { "type": "string" },
        "labels": { "$ref": "#/$defs/annotations" },
        "usage": { "$ref": "#/$defs/usage" },
        "prompt_used": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
